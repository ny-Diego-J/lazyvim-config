<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<profiles version="12">
    <profile kind="CodeFormatterProfile" name="Custom-Java-Style" version="12">
        <setting id="org.eclipse.jdt.core.formatter.tabulation.char" value="space"/>
        <setting id="org.eclipse.jdt.core.formatter.tabulation.size" value="4"/>
        <setting id="org.eclipse.jdt.core.formatter.indentation.size" value="4"/>

        <setting id="org.eclipse.jdt.core.formatter.keep_simple_if_on_one_line" value="true"/>
        <setting id="org.eclipse.jdt.core.formatter.keep_simple_else_on_one_line" value="true"/>
        <setting id="org.eclipse.jdt.core.formatter.keep_simple_for_on_one_line" value="true"/>
        <setting id="org.eclipse.jdt.core.formatter.keep_simple_while_on_one_line" value="true"/>

        <setting id="org.eclipse.jdt.core.formatter.lineSplit" value="240"/>

        <setting id="org.eclipse.jdt.core.formatter.brace_position_for_block" value="end_of_line"/>
        <setting id="org.eclipse.jdt.core.formatter.brace_position_for_method_declaration" value="end_of_line"/>
        <setting id="org.eclipse.jdt.core.formatter.brace_position_for_type_declaration" value="end_of_line"/>
        <setting id="org.eclipse.jdt.core.formatter.keep_then_statement_on_same_line" value="true"/>
        <setting id="org.eclipse.jdt.core.formatter.keep_else_statement_on_same_line" value="true"/>
        <setting id="org.eclipse.jdt.core.formatter.number_of_empty_lines_to_preserve" value="1"/>
    </profile>
</profiles>